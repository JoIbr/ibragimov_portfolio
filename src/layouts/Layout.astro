---
import "../styles/layout.css";
import { ClientRouter } from "astro:transitions";

interface Props {
	titleRu?: string;
	titleEn?: string;
	showBack?: boolean;
}

const { titleRu = "Портфолио", titleEn = "Portfolio", showBack = false } = Astro.props;
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isCasePage = pathname.startsWith("/cases");

const tabs = [
	{ href: "/", ru: "Кейсы", en: "Cases" },
	{ href: "/about", ru: "Обо мне", en: "About" },
	{ href: "/contact", ru: "Контакты", en: "Contacts" },
];
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{titleRu}</title>
		<link rel="preload" href="/fonts/TT-Neoris-Regular.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/TT-Neoris-Medium.woff2" as="font" type="font/woff2" crossorigin />
		<ClientRouter />
	</head>
	<body data-title-ru={titleRu} data-title-en={titleEn}>
		<aside class="sidebar">
			<div class="sidebar-content">
				<h1>
					<a href="/" style="all: unset; cursor: pointer">Ibragimov Javohir</a>
				</h1>
				<div class="sidebar-content-item">
					<p class="subtitle" data-i18n-ru="Выполненные продуктовые кейсы" data-i18n-en="Completed product cases">
						Выполненные продуктовые кейсы
					</p>
					<p class="subtitle-since">since 2023-2026</p>
				</div>
			</div>
			<a class="contact-link" href="/contact" data-i18n-ru="Связаться со мной →" data-i18n-en="Contact me →">
				Связаться со мной →
			</a>
			<button id="mobile-header-lang" class="sidebar-lang" type="button">РУС</button>
		</aside>

		<div class="content-shell">
			<header class="tabs">
				{showBack ? (
					<a href="/" class="back-btn">
    					← <span data-i18n-ru="Назад" data-i18n-en="Back">Назад</span>
  					</a>
				) : (
					<a
					class={`tab ${pathname === "/" ? "active" : ""}`}
					href="/"
					data-i18n-ru="Кейсы"
					data-i18n-en="Cases">
					</a>
				)}
				{tabs.slice(1).map((tab) => (
					<a
						class={`tab ${pathname === tab.href ? "active" : ""}`}
						href={tab.href}
						data-i18n-ru={tab.ru}
						data-i18n-en={tab.en}
					>
						{tab.ru}
					</a>
				))}
				<button id="lang-toggle" class="lang" type="button">РУС</button>
			</header>
			<main>
				<slot />
			</main>
		</div>

		<nav class="mobile-nav">
			{showBack ? (
				<a href="/" class="mobile-tab mobile-back">
					← <span data-i18n-ru="Назад" data-i18n-en="Back">Назад</span>
				</a>
			) : (
				<a
					class={`mobile-tab ${pathname === "/" || isCasePage ? "active" : ""}`}
					href="/"
					data-i18n-ru="Кейсы"
					data-i18n-en="Cases"
				>Кейсы</a>
			)}
			<a
				class={`mobile-tab ${pathname === "/about" ? "active" : ""}`}
				href="/about"
				data-i18n-ru="Обо мне"
				data-i18n-en="About"
			>Обо мне</a>
			<a
				class={`mobile-tab ${pathname === "/contact" ? "active" : ""}`}
				href="/contact"
				data-i18n-ru="Контакты"
				data-i18n-en="Contacts"
			>Контакты</a>
		</nav>

		<script is:inline>
			const LANG_KEY = "site-lang";
			let _scrollController = null;

			function applyLanguage(lang) {
				const safeLang = lang === "en" ? "en" : "ru";
				document.documentElement.lang = safeLang;
				localStorage.setItem(LANG_KEY, safeLang);

				const title = document.body.dataset[`title${safeLang === "ru" ? "Ru" : "En"}`];
				if (title) document.title = title;

				document.querySelectorAll("[data-i18n-ru][data-i18n-en]").forEach((el) => {
					el.textContent = safeLang === "ru" ? el.dataset.i18nRu : el.dataset.i18nEn;
				});

				const ruBlocks = document.querySelectorAll(".lang-ru");
				const enBlocks = document.querySelectorAll(".lang-en");

				ruBlocks.forEach(el => el.style.display = safeLang === "ru" ? "" : "none");
				enBlocks.forEach(el => el.style.display = safeLang === "en" ? "" : "none");

				const toggle = document.getElementById("lang-toggle");
				if (toggle) toggle.textContent = safeLang === "ru" ? "РУС" : "ENG";

				const headerLang = document.getElementById("mobile-header-lang");
				if (headerLang) headerLang.textContent = safeLang === "ru" ? "РУС" : "ENG";
			}

			function initScroll() {
				if (_scrollController) _scrollController.abort();
				_scrollController = new AbortController();

				const sidebar = document.querySelector(".sidebar");
				if (!sidebar) return;

				let lastY = window.scrollY;

				window.addEventListener("scroll", () => {
					const currentY = window.scrollY;
					if (currentY > lastY && currentY > 60) {
						sidebar.classList.add("header-hidden");
					} else {
						sidebar.classList.remove("header-hidden");
					}
					lastY = currentY;
				}, { passive: true, signal: _scrollController.signal });
			}

			function init() {
				const lang = localStorage.getItem(LANG_KEY) || "ru";
				applyLanguage(lang);

				const toggle = document.getElementById("lang-toggle");
				toggle?.addEventListener("click", () => {
					const next = (localStorage.getItem(LANG_KEY) || "ru") === "ru" ? "en" : "ru";
					applyLanguage(next);
				});

				const headerLang = document.getElementById("mobile-header-lang");
				headerLang?.addEventListener("click", () => {
					const next = (localStorage.getItem(LANG_KEY) || "ru") === "ru" ? "en" : "ru";
					applyLanguage(next);
				});

				initScroll();
			}

			document.addEventListener("astro:page-load", init);
		</script>
	</body>
</html>
