---
import Layout from "../layouts/Layout.astro";
import "../styles/index.css";
import { projects } from "../data/projects.ts";
---

<Layout
	titleRu="Жавохир Ибрагимов — UI/UX дизайнер | Портфолио и кейсы"
	titleEn="Javohir Ibragimov — UI/UX Designer | Portfolio & Cases"
	descriptionRu="Портфолио UI/UX дизайнера Жавохира Ибрагимова из Ташкента. Продуктовые кейсы: CRM и POS-системы, мобильные приложения, веб-интерфейсы для Lume, TVCOM, Comnet и Dost Logistics."
	descriptionEn="UI/UX designer Javohir Ibragimov's portfolio, based in Tashkent. Product case studies: CRM and POS systems, mobile apps and web interfaces for Lume, TVCOM, Comnet and Dost Logistics."
>
	<section class="info-tooltip">
		<img src="/icons/info.svg" alt="">
		<h3 class="info-title">
			<span
				class="info-span-title"
				data-i18n-ru="Это лишь часть моего портфолио."
				data-i18n-en="This is just a small selection from my portfolio."
			></span>
		
			<br>
		
			<span
				class="info-p"
				data-i18n-ru='Здесь представлены не все мои работы. Новые кейсы публикуются по мере подготовки подробных описаний. Если возникнут вопросы, пожалуйста, напишите мне в '
				data-i18n-en='Not all of my projects are showcased here. New case studies are added as detailed descriptions are prepared. If you have any questions, feel free to contact me via '
			></span>

			<a href="https://t.me/javaibr" target="_blank">Telegram</a>
		</h3>
	</section>
	<section class="grid">
		{projects.map((project, i) => (
			project.slug ? (
				<a href={`/cases/${project.slug}`} class="card">
					<div class="thumb">
					{project.cover && <img src={project.cover} alt={project.titleRu} loading={i === 0 ? "eager" : "lazy"} fetchpriority={i === 0 ? "high" : "auto"} />}
					</div>
					<h3 data-i18n-ru={project.titleRu} data-i18n-en={project.titleEn}>{project.titleRu}</h3>
					<p data-i18n-ru={project.descriptionRu} data-i18n-en={project.descriptionEn}>
						{project.descriptionRu}
					</p>
				</a>
			) : (
				<div class="card">
					<div class="thumb">
					{project.cover && <img src={project.cover} alt={project.titleRu} loading={i === 0 ? "eager" : "lazy"} fetchpriority={i === 0 ? "high" : "auto"} />}
					</div>
					<h3 data-i18n-ru={project.titleRu} data-i18n-en={project.titleEn}>{project.titleRu}</h3>
					<p data-i18n-ru={project.descriptionRu} data-i18n-en={project.descriptionEn}>
						{project.descriptionRu}
					</p>
				</div>
			)
		))}
	</section>
</Layout>
