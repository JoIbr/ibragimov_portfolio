---
import Layout from "../layouts/Layout.astro";
import "../styles/page-section.css";
---

<Layout
	titleRu="Контакты — Жавохир Ибрагимов, UI/UX дизайнер"
	titleEn="Contacts — Javohir Ibragimov, UI/UX Designer"
	descriptionRu="Связаться с UI/UX дизайнером Жавохиром Ибрагимовым: Telegram, LinkedIn, email. Открыт для проектов и сотрудничества."
	descriptionEn="Get in touch with UI/UX designer Javohir Ibragimov via Telegram, LinkedIn or email. Open to new projects and collaboration."
>
	<section class="section">
		<div class="socials">
			<p id="social" data-i18n-ru="Социальные сети" data-i18n-en="Socials"></p>
			<table class="contacts-table">
				<tbody>
				  <tr>
					<td class="contact-name">Telegram</td>
					<td class="contact-mail">
						<a href="https://t.me/javaibr">
						  <span data-i18n-ru="Перейти (@javaibr)" data-i18n-en="Write (@javaibr)"></span> →
						</a>
					  </td>
				  </tr>
				  <tr>
					<td class="contact-name">LinkedIn</td>
					<td class="contact-mail">
						<a href="https://www.linkedin.com/in/javaibr/">
						  <span data-i18n-ru="Перейти" data-i18n-en="Write"></span> →
						</a>
					  </td>
				  </tr>
				</tbody>
			</table>
		</div>

		<div class="mail">
			<p id="mail" data-i18n-ru="EMAIL" data-i18n-en="EMAIL"></p>
			<table class="contacts-table">
				<tbody>
				  <tr>
					<td class="contact-name">javohiribr@gmail.com</td>
					<td class="contact-mail">
						<a href="mailto:javohirbr@gmail.com">
						  <span data-i18n-ru="Написать" data-i18n-en="Write"></span> →
						</a>
					  </td>
				  </tr>
				</tbody>
			</table>
		</div>
	</section>
</Layout>