---
import "../styles/layout.css";
import "../styles/page-section.css";
import { ClientRouter } from "astro:transitions";
import { SITE } from "../data/site.ts";

interface Props {
	titleRu?: string;
	titleEn?: string;
	descriptionRu?: string;
	descriptionEn?: string;
	image?: string;
	type?: string;
	noindex?: boolean;
	showBack?: boolean;
}

const DEFAULT_DESC_RU =
	"Портфолио Жавохира Ибрагимова — UI/UX дизайнера из Ташкента. Продуктовые кейсы: CRM, POS-системы, мобильные приложения и веб-интерфейсы.";
const DEFAULT_DESC_EN =
	"Portfolio of Javohir Ibragimov — UI/UX designer based in Tashkent. Product case studies: CRM, POS systems, mobile apps and web interfaces.";

const {
	titleRu = "Жавохир Ибрагимов — UI/UX дизайнер",
	titleEn = "Javohir Ibragimov — UI/UX Designer",
	descriptionRu = DEFAULT_DESC_RU,
	descriptionEn = DEFAULT_DESC_EN,
	image = SITE.defaultImage,
	type = "website",
	noindex = false,
	showBack = false,
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isCasePage = pathname.startsWith("/cases");

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? SITE.url).href;
const ogImage = new URL(image, Astro.site ?? SITE.url).href;

// Structured data so search engines understand who the site is about.
const jsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "Person",
			"@id": `${SITE.url}/#person`,
			name: SITE.authorName,
			alternateName: SITE.authorNameRu,
			jobTitle: SITE.jobTitleEn,
			url: SITE.url,
			image: new URL(SITE.photo, SITE.url).href,
			address: {
				"@type": "PostalAddress",
				addressLocality: "Tashkent",
				addressCountry: "UZ",
			},
			sameAs: SITE.sameAs,
		},
		{
			"@type": "WebSite",
			"@id": `${SITE.url}/#website`,
			url: SITE.url,
			name: `${SITE.authorName} — ${SITE.jobTitleEn}`,
			inLanguage: ["ru", "en"],
			author: { "@id": `${SITE.url}/#person` },
		},
	],
};

const tabs = [
	{ href: "/", ru: "Кейсы", en: "Cases" },
	{ href: "/about", ru: "Обо мне", en: "About" },
	{ href: "/contact", ru: "Контакты", en: "Contacts" },
];
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="yandex-verification" content="1d319b28641edae4" />

		<title>{titleRu}</title>
		<meta name="description" content={descriptionRu} />
		<meta name="author" content={SITE.authorName} />
		<link rel="canonical" href={canonicalURL} />
		{noindex
			? <meta name="robots" content="noindex, nofollow" />
			: <meta name="robots" content="index, follow, max-image-preview:large" />}
		<meta name="theme-color" content="#ffffff" />

		<!-- Open Graph -->
		<meta property="og:type" content={type} />
		<meta property="og:site_name" content={SITE.authorName} />
		<meta property="og:title" content={titleRu} />
		<meta property="og:description" content={descriptionRu} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:alt" content={titleRu} />
		<meta property="og:locale" content={SITE.locale} />
		<meta property="og:locale:alternate" content={SITE.localeAlternate} />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={titleRu} />
		<meta name="twitter:description" content={descriptionRu} />
		<meta name="twitter:image" content={ogImage} />
		{SITE.twitter && <meta name="twitter:creator" content={SITE.twitter} />}

		<link rel="preload" href="/fonts/TT-Neoris-Regular.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/TT-Neoris-Medium.woff2" as="font" type="font/woff2" crossorigin />

		<script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

		<ClientRouter />
	</head>
	<body
		data-title-ru={titleRu}
		data-title-en={titleEn}
		data-desc-ru={descriptionRu}
		data-desc-en={descriptionEn}
	>
		<aside class="sidebar">
			<div class="sidebar-content">
				<h1>
					<a href="/" style="all: unset; cursor: pointer">Ibragimov Javohir</a>
				</h1>
				<div class="sidebar-content-item">
					<p class="subtitle" data-i18n-ru="Выполненные продуктовые кейсы" data-i18n-en="Completed product cases">
						Выполненные продуктовые кейсы
					</p>
					<p class="subtitle-since">since 2023</p>
				</div>
			</div>
			<a class="contact-link" href="/contact" data-i18n-ru="Связаться со мной →" data-i18n-en="Contact me →">
				Связаться со мной →
			</a>
			<button id="mobile-header-lang" class="sidebar-lang" type="button">РУС</button>
		</aside>

		<div class="content-shell">
			<header class="tabs">
				{showBack ? (
					<a href="/" class="back-btn">
    					← <span data-i18n-ru="Назад" data-i18n-en="Back">Назад</span>
  					</a>
				) : (
					<a
					class={`tab ${pathname === "/" ? "active" : ""}`}
					href="/"
					data-i18n-ru="Кейсы"
					data-i18n-en="Cases">
					</a>
				)}
				{tabs.slice(1).map((tab) => (
					<a
						class={`tab ${pathname === tab.href ? "active" : ""}`}
						href={tab.href}
						data-i18n-ru={tab.ru}
						data-i18n-en={tab.en}
					>
						{tab.ru}
					</a>
				))}
				<button id="lang-toggle" class="lang" type="button">РУС</button>
			</header>
			<main>
				<slot />
			</main>
		</div>

		<nav class="mobile-nav">
			{showBack ? (
				<a href="/" class="mobile-tab mobile-back">
					← <span data-i18n-ru="Назад" data-i18n-en="Back">Назад</span>
				</a>
			) : (
				<a
					class={`mobile-tab ${pathname === "/" || isCasePage ? "active" : ""}`}
					href="/"
					data-i18n-ru="Кейсы"
					data-i18n-en="Cases"
				>Кейсы</a>
			)}
			<a
				class={`mobile-tab ${pathname === "/about" ? "active" : ""}`}
				href="/about"
				data-i18n-ru="Обо мне"
				data-i18n-en="About"
			>Обо мне</a>
			<a
				class={`mobile-tab ${pathname === "/contact" ? "active" : ""}`}
				href="/contact"
				data-i18n-ru="Контакты"
				data-i18n-en="Contacts"
			>Контакты</a>
		</nav>

		<script is:inline>
			const LANG_KEY = "site-lang";
			let _scrollController = null;

			function applyLanguage(lang) {
				const safeLang = lang === "en" ? "en" : "ru";
				document.documentElement.lang = safeLang;
				localStorage.setItem(LANG_KEY, safeLang);

				const suffix = safeLang === "ru" ? "Ru" : "En";
				const title = document.body.dataset[`title${suffix}`];
				if (title) document.title = title;

				const desc = document.body.dataset[`desc${suffix}`];
				const descMeta = document.querySelector('meta[name="description"]');
				if (desc && descMeta) descMeta.setAttribute("content", desc);

				document.querySelectorAll("[data-i18n-ru][data-i18n-en]").forEach((el) => {
					el.textContent = safeLang === "ru" ? el.dataset.i18nRu : el.dataset.i18nEn;
				});

				const ruBlocks = document.querySelectorAll(".lang-ru");
				const enBlocks = document.querySelectorAll(".lang-en");

				ruBlocks.forEach(el => el.style.display = safeLang === "ru" ? "" : "none");
				enBlocks.forEach(el => el.style.display = safeLang === "en" ? "" : "none");

				const toggle = document.getElementById("lang-toggle");
				if (toggle) toggle.textContent = safeLang === "ru" ? "РУС" : "ENG";

				const headerLang = document.getElementById("mobile-header-lang");
				if (headerLang) headerLang.textContent = safeLang === "ru" ? "РУС" : "ENG";
			}

			function initScroll() {
				if (_scrollController) _scrollController.abort();
				_scrollController = new AbortController();

				const sidebar = document.querySelector(".sidebar");
				if (!sidebar) return;

				let lastY = window.scrollY;

				window.addEventListener("scroll", () => {
					const currentY = window.scrollY;
					if (currentY > lastY && currentY > 60) {
						sidebar.classList.add("header-hidden");
					} else {
						sidebar.classList.remove("header-hidden");
					}
					lastY = currentY;
				}, { passive: true, signal: _scrollController.signal });
			}

			function init() {
				const lang = localStorage.getItem(LANG_KEY) || "ru";
				applyLanguage(lang);

				const toggle = document.getElementById("lang-toggle");
				toggle?.addEventListener("click", () => {
					const next = (localStorage.getItem(LANG_KEY) || "ru") === "ru" ? "en" : "ru";
					applyLanguage(next);
				});

				const headerLang = document.getElementById("mobile-header-lang");
				headerLang?.addEventListener("click", () => {
					const next = (localStorage.getItem(LANG_KEY) || "ru") === "ru" ? "en" : "ru";
					applyLanguage(next);
				});

				initScroll();
			}

			document.addEventListener("astro:page-load", init);
		</script>
	</body>
</html>
