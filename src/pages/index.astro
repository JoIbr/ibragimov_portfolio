---
import Layout from "../layouts/Layout.astro";
import "../styles/index.css";
import { projects } from "../data/projects.ts";
---

<Layout titleRu="Кейсы | Portfolio" titleEn="Cases | Portfolio">
	<section class="info-tooltip">
		<img src="./icons/info.svg" alt="">
		<h3 class="info-title">Это лишь часть моего портфолио.
			<br><span class="info-p">Здесь представлены не все мои работы. Новые кейсы публикуются по мере подготовки подробных описаний. Если возникнут вопросы, пожалуйста напишите мне в <a href="https://t.me/javaibr" target="_blank">Telegram</a></span>
		</h3>
	</section>
	<section class="grid">
		{projects.map((project) => (
			project.slug ? (
				<a href={`/cases/${project.slug}`} class="card">
					<div class="thumb">
					{project.cover && <img src={project.cover} alt={project.titleRu} />}
					</div>
					<h3 data-i18n-ru={project.titleRu} data-i18n-en={project.titleEn}>{project.titleRu}</h3>
					<p data-i18n-ru={project.descriptionRu} data-i18n-en={project.descriptionEn}>
						{project.descriptionRu}
					</p>
				</a>
			) : (
				<div class="card">
					<div class="thumb">
					{project.cover && <img src={project.cover} alt={project.titleRu} />}
					</div>
					<h3 data-i18n-ru={project.titleRu} data-i18n-en={project.titleEn}>{project.titleRu}</h3>
					<p data-i18n-ru={project.descriptionRu} data-i18n-en={project.descriptionEn}>
						{project.descriptionRu}
					</p>
				</div>
			)
		))}
	</section>
</Layout>
