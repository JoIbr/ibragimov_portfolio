---
import Layout from "../layouts/Layout.astro";
import "../styles/index.css";

const projects = [
	{
		titleRu: "Comnet Colocation Webpage",
		titleEn: "Comnet Colocation Webpage",
		descriptionRu: "Оптимизация интерфейса для увеличения количества заявок.",
		descriptionEn: "Optimizing the interface to increase request volume.",
		slug: "comnet_colocation",
		cover: "/images/cases/comnet/cover.webp"
	},
	{
		titleRu: "Comnet Deposit Logic",
		titleEn: "Comnet Deposit Logic",
		descriptionRu: "Удобные пополнения карты для роста лидогенерации.",
		descriptionEn: "Convenient card top-ups to boost lead generation.",
		slug: null,
		cover: null
	},
	{
		titleRu: "TVCOM App",
		titleEn: "TVCOM App",
		descriptionRu: "Полный редизайн мобильного приложения.",
		descriptionEn: "Complete redesign of the mobile app.",
		slug: null,
		cover: null
	},
	{
		titleRu: "Кейс #4",
		titleEn: "Case #4",
		descriptionRu: "Описание проекта скоро будет добавлено.",
		descriptionEn: "Project description will be added soon.",
		slug: null,
		cover: null
	},
	{
		titleRu: "Кейс #5",
		titleEn: "Case #5",
		descriptionRu: "Описание проекта скоро будет добавлено.",
		descriptionEn: "Project description will be added soon.",
		slug: null,
		cover: null
	},
	{
		titleRu: "Кейс #6",
		titleEn: "Case #6",
		descriptionRu: "Описание проекта скоро будет добавлено.",
		descriptionEn: "Project description will be added soon.",
		slug: null,
		cover: null
	},
];
---

<Layout titleRu="Кейсы | Portfolio" titleEn="Cases | Portfolio">
	<section class="grid">
		{projects.map((project) => (
			project.slug ? (
				<a href={`/cases/${project.slug}`} class="card">
					<div class="thumb">
					{project.cover && <img src={project.cover} alt={project.titleRu} />}
					</div>
					<h3 data-i18n-ru={project.titleRu} data-i18n-en={project.titleEn}>{project.titleRu}</h3>
					<p data-i18n-ru={project.descriptionRu} data-i18n-en={project.descriptionEn}>
						{project.descriptionRu}
					</p>
				</a>
			) : (
				<div class="card">
					<div class="thumb">
					{project.cover && <img src={project.cover} alt={project.titleRu} />}
					</div>
					<h3 data-i18n-ru={project.titleRu} data-i18n-en={project.titleEn}>{project.titleRu}</h3>
					<p data-i18n-ru={project.descriptionRu} data-i18n-en={project.descriptionEn}>
						{project.descriptionRu}
					</p>
				</div>
			)
		))}
	</section>
</Layout>
